{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "paths": {
      "@common/*": ["src/common/*"],
      "@modules/*": ["src/modules/*"],
      "@prisma-client": ["src/prisma/prisma.service"]
    },
    "incremental": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "strictNullChecks": true,
    "strict": true
  }
}

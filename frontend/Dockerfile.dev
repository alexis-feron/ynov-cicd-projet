# ──────────────────────────────────────────────
#  Development image - source mounted via volume
# ──────────────────────────────────────────────
FROM alpine:3.21

WORKDIR /app

RUN apk add --no-cache dumb-init nodejs npm

COPY package*.json ./

# Sync the lock file (it may still reference the removed Windows-only SWC
# binary on first build), then install with optional deps so Next.js can
# pull its musl SWC binary for Alpine.
RUN npm install --package-lock-only --ignore-scripts && npm ci

EXPOSE 3000

ENTRYPOINT ["dumb-init", "--"]
CMD ["npm", "run", "dev"]
